generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  REQUESTER
  STAFF
}

enum Provider {
  GOOGLE
  PASSWORD
}

enum NotificationPref {
  OFF
  MY_UPDATES
  NEW_MESSAGES
  ALL
}

enum Availability {
  AVAILABLE
  BUSY
  AWAY
}

enum MessageType {
  TEXT
  QUICK
  REQUEST
  SYSTEM
}

enum Status {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

model Group {
  id        String    @id @default(cuid())
  key       String    @unique
  nameKey   String
  createdAt DateTime  @default(now())
  messages  Message[]
}

model Message {
  id        String      @id @default(cuid())
  groupId   String
  group     Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User        @relation(fields: [senderId], references: [id])
  type      MessageType @default(TEXT)
  text      String?
  payload   Json?
  status    Status?
  summary   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([groupId, createdAt])
}

model User {
  id                String           @id @default(cuid())
  name              String
  email             String           @unique
  photoUrl          String?
  passwordHash      String?
  provider          Provider         @default(PASSWORD)
  providerId        String?
  role              Role             @default(REQUESTER)
  locale            String           @default("en")
  notificationPref  NotificationPref @default(ALL)
  availability      Availability     @default(AVAILABLE)
  availabilityNote  String?
  availabilityUntil DateTime?
  addOns            String[]         @default([])
  createdAt         DateTime         @default(now())
  messages          Message[]
}
